{
  "name": "@monkvision/e2e",
  "version": "1.0.0",
  "private": true,
  "description": "End-to-end tests for MonkJs demo apps",
  "author": "monkvision",
  "license": "BSD-3-Clause-Clear",
  "scripts": {
    "postinstall": "playwright install chromium",
    "test": "playwright test",
    "test:demo-app": "playwright test --project=demo-app",
