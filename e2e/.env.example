# Required for both apps
TEST_TOKEN=

# App base URLs — must use different ports. Defaults match the webServer PORT in playwright.config.ts.
# The webServer derives PORT= from these URLs, so the app always starts on the same port it is probed on.
DEMO_APP_URL=https://localhost:17200
DEMO_VIDEO_APP_URL=https://localhost:17201

# Monk API domain used by the apps
API_DOMAIN=api.preview.monk.ai/v1
