{
  "name": "monkjs",
  "packageManager": "yarn@3.2.4",
  "description": "Monorepo for the MonkJs project",
  "private": true,
  "type": "module",
  "author": "monkvision",
  "license": "BSD-3-Clause-Clear",
  "workspaces": [
    "packages/*",
    "configs/*",
    "apps/*",
    "documentation",
    "e2e"
  ],
  "scripts": {
    "repair": "lerna repair",
    "clean": "rimraf node_modules && yarn cache clean && yarn install",
    "clean:all": "lerna run clean --parallel && rimraf node_modules && yarn cache clean && yarn install",
    "build": "yarn run build:development",
    "build:development": "lerna run build:development --scope '@monkvision/*'",
    "build:production": "lerna run build:production --scope '@monkvision/*'",
    "build:documentation": "lerna run build --scope 'monk-documentation'",
    "version": "yarn install && git stage yarn.lock",
    "release:pr": "lerna version --force-publish --exact --no-push && NEW_VERSION=$(node -p \"require('./lerna.json').version\") && git checkout -b release/v$NEW_VERSION && git push -u origin HEAD && gh pr create --title \"Release MonkJs v$NEW_VERSION\" --fill --base main",
    "deploy:packages": "yarn run build:production && lerna publish from-package --force-publish --yes",
    "deploy:documentation": "lerna run deploy --scope 'monk-documentation'",
    "test": "lerna run test --parallel --ignore '@monkvision/e2e'",
    "test:packages": "lerna run test --parallel --scope '@monkvision/*'",
    "test:coverage": "lerna run test:coverage --parallel",
    "lint": "lerna run --parallel lint",
    "lint:fix": "lerna run --parallel lint:fix",
    "e2e": "yarn workspace @monkvision/e2e test",
    "e2e:ui": "yarn workspace @monkvision/e2e test:ui",
    "e2e:demo-app": "yarn workspace @monkvision/e2e test:demo-app",
    "e2e:demo-app-video": "yarn workspace @monkvision/e2e test:demo-app-video",
    "ci": "yarn && yarn build && yarn test && yarn lint",
    "svgo": "lerna run svgo --parallel"
  },
  "dependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "lerna": "^9.0.7",
    "rimraf": "^3.0.2"
  },
  "resolutions": {
    "underscore": "1.13.8",
    "serialize-javascript": "7.0.5",
    "nth-check": "^2.0.1",
    "uuid": "^11.1.1",
    "resolve-url-loader": "^5.0.0",
    "form-data": "^4.0.6",
    "tmp": "^0.2.7",
    "http-proxy-middleware": "^2.0.10",
    "tar": "^7.5.16",
    "undici": "^6.27.0",
    "joi": "^17.13.4",
    "dompurify": "^3.4.11"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monkvision/monkjs.git"
  },
  "bugs": {
    "url": "https://github.com/monkvision/monkjs/issues"
  },
  "homepage": "https://github.com/monkvision/monkjs"
}
