{
  "compilerOptions": {
    "target": "es5",
    "module": "commonjs",
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "declaration": true,
    "outDir": "dist",
    "skipLibCheck": true,
    "lib": ["es5", "dom"],
    "types": ["cypress", "./cypress/support"],
    "allowJs": true
  },
  "include": ["cypress/**/*", "config/**/*"],
  "exclude": ["node_modules"]
}
