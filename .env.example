# MCP server secrets. Copy this file to `.env` and fill in real values.
# `.env` is git-ignored — never commit real tokens.
#
# GitHub MCP server (.mcp.json → github). Create a token at:
#   https://github.com/settings/personal-access-tokens
# See .claude/MCP.md for the required scopes and org-approval notes.
GITHUB_PERSONAL_ACCESS_TOKEN=

# Comma-separated toolsets to enable beyond the server's default set.
# "dependabot" is required for the /fix-dependabot skill (list/get alerts).
GITHUB_TOOLSETS=dependabot

# Add future MCP keys below, one per line (KEY=value).
